
<odoo>
    <record id="view_res_users_mrbook_inherit" model="ir.ui.view">
        <field name="name">res.users.mrbook.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_bookings"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-calendar">
                        <field name="booking_count" string="Bookings" widget="statinfo"/>
                    </button>
                </div>
            </xpath>
            <!-- <notebook position="inside"> I can also do that -->
            <xpath expr="//notebook" position="inside">
                <page string="Bookings">
                    <field name="booking_ids">
                        <list>
                            <field name="reference"/>
                            <field name="room_id"/>
                            <field name="start_datetime"/>
                            <field name="status"/>
                        </list>
                    </field>
                </page>
            </xpath>
            <!--</notebook>-->

        </field>
    </record>
</odoo>