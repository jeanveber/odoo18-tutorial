<odoo>
    <data>
        <!-- Kanban view -->
        <record id="view_mrbook_booking_kanban" model="ir.ui.view">
        <field name="name">mrbook.booking.kanban</field>
        <field name="model">mrbook.booking</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div>
                            <field name="reference"/>
                            <div>
                                <field name="amenity_ids" widget="many2many_tags" options="{'color_field': 'color'}" readonly="True"/>
                                <field name="room_id"/>
                                <div>
                                    <field name="status"/>
                                </div>

                                <div t-if="record.status.raw_value == 'confirmed'">
                                    <field name="duration"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
        </record>

               <!-- booking search -->
        <record id="view_mrbook_booking_search" model="ir.ui.view">
            <field name="name">mrbook.booking.search</field>
            <field name="model">mrbook.booking</field>
            <field name="arch" type="xml">
            <search string="Booking Search">

                <field name="reference" string="ID"/>

                <filter name="confirmed" string="Confirmed" domain="[('status','=','confirmed')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('status','=','cancelled')]"/>
                <filter name="draft" string="Draft" domain="[('status','=','draft')]"/>

            </search>
            </field>
        </record>


        <!-- booking form -->
        <record id="view_mrbook_booking_form" model="ir.ui.view">
            <field name="name">mrbook.booking.form</field>
            <field name="model">mrbook.booking</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" type="object" string = "Confirm"/>
                        <button name="action_draft" type="object" string = "Draft" invisible= "status!='confirmed'"/>
                        <button name="action_cancel" type="object" string = "Cancel" invisible="status=='cancelled'"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="reference" readonly="True"/>
                                <field name="room_id"/>
                                <field name="amenity_ids" widget="many2many_tags" options="{'color_field': 'color'}" readonly="True"/>
                                <field name="user_id"/>
                                <field name="status" decoration-success="status=='confirmed'"
                           decoration-muted="status=='draft'"
                           decoration-danger="status=='cancelled'"/>
                            </group>
                            <group>
                                <field name="start_datetime"/>
                                <field name="end_datetime"/>
                                <field name="duration"/>
                            </group>
                        </group>
                        <field name="notes"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <!-- Booking List -->
        <record id="view_mrbook_booking_list" model="ir.ui.view">
            <field name="name">mrbook.booking.list</field>
            <field name="model">mrbook.booking</field>
            <field name="arch" type="xml">
                <list  create="false">
                    <field name="reference"/>
                    <field name="room_id"/>
                    <field name="user_id"/>
                    <field name="user_email"/>
                    <field name="start_datetime"/>
                    <field name="end_datetime"/>
                    <field name="duration"/>
                    <field name="status" decoration-success="status=='confirmed'"
                           decoration-muted="status=='draft'"
                           decoration-danger="status=='cancelled'"/>
                </list>
            </field>
        </record>


        <record id="action_mrbook_booking" model="ir.actions.act_window">
            <field name="name">Bookings</field>
            <field name="res_model">mrbook.booking</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

    </data>
</odoo>