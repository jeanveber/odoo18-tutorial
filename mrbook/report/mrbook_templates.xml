

<odoo>
    <template id="mrbook_booking_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Booking: <t t-esc="doc.reference"/></h2>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Room:</strong>
                                <p><t t-esc="doc.room_id.name"/></p>
                            </div>
                            <div class="col-6">
                                <strong>Booked By:</strong>
                                <p><t t-esc="doc.user_id.name"/></p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Start:</strong>
                                <p><t t-esc="doc.start_datetime"/></p>
                            </div>
                            <div class="col-6">
                                <strong>End:</strong>
                                <p><t t-esc="doc.end_datetime"/></p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Duration:</strong>
                                <p><t t-esc="doc.duration"/> hours</p>
                            </div>
                            <div class="col-6">
                                <strong>Status:</strong>
                                <p><t t-esc="doc.status"/></p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <strong>Notes:</strong>
                                <p><t t-esc="doc.notes"/></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>