<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_dispatch_request_list" model="ir.ui.view">
        <field name="name">dispatch.request.list</field>
        <field name="model">dispatch.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_name"/>
                <field name="plumber_id"/>
                <field name="date_scheduled"/>
                <field name="status"/>
                <field name="duration_label"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_dispatch_request_form" model="ir.ui.view">
        <field name="name">dispatch.request.form</field>
        <field name="model">dispatch.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="client_name"/>
                        <field name="client_address"/>
                        <field name="plumber_id"/>
                        <field name="date_scheduled"/>
                        <field name="duration_label"/>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action 1: My Requests -->
    <record id="action_my_dispatch_requests" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">dispatch.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('plumber_id', '=', uid)]</field>
    </record>

    <!-- Action 2: All Requests -->
    <record id="action_all_dispatch_requests" model="ir.actions.act_window">
        <field name="name">All Requests</field>
        <field name="res_model">dispatch.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_plumber_root" name="Plumber Dispatch" sequence="10"/>
    <menuitem id="menu_my_requests" name="My Requests"
              parent="menu_plumber_root"
              action="action_my_dispatch_requests" sequence="10"/>
    <menuitem id="menu_all_requests" name="All Requests"
              parent="menu_plumber_root"
              action="action_all_dispatch_requests" sequence="20"
              groups="plumber.group_dispatch_admin"/>
</odoo>